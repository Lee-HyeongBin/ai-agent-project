# =========================================================================
#  AgentPlatform .env.example
# =========================================================================
#  이 파일은 git에 커밋됩니다. 절대 실제 키를 여기에 넣지 마세요.
#  실제 키는 .env 파일 (git ignored) 에만 넣습니다:
#
#    cp .env.example .env
#    # 그런 다음 .env 를 편집해서 진짜 키 입력
#
#  2026-05-13 인시던트: .env.example 에 실제 Anthropic 키가 들어가
#  GitHub push protection 으로 차단된 적 있음. 같은 실수 금지.
# =========================================================================

# Anthropic Claude API key — https://console.anthropic.com/settings/keys
# 이 라인의 placeholder 그대로 두고, 실제 키는 .env 에 작성.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# LLM 모델 (기본: Sonnet 4.6)
ANTHROPIC_MODEL=claude-sonnet-4-6
